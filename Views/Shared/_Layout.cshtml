@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var loggedUserName = User.Identity?.Name ?? "User";

    var usersActive = string.Equals(currentController, "USERS", StringComparison.OrdinalIgnoreCase);
    var adminActive = string.Equals(currentController, "ADMIN", StringComparison.OrdinalIgnoreCase);
    var surveyActive = string.Equals(currentController, "SURVEYS", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - FeedBack</title>

    <link rel="icon" href="~/lib/images/RTS_emoji.ico" type="image/x-icon">

    @* BOOSTRAP 5 *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />

    @* FONT AWESOME *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    @* jQUERY *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

    @* IZITOAST *@
    <link href="https://cdn.jsdelivr.net/npm/izitoast@1.4.0/dist/css/iziToast.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/izitoast@1.4.0/dist/js/iziToast.min.js"></script>


    @* DATA TABLE JS *@
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.8/css/dataTables.dataTables.min.css">
    <!-- DataTables Responsive CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.6/css/responsive.dataTables.min.css">

    @* CHAT JS *@
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>
<body>
    <div id="global-loading-overlay" class="global-loading-overlay" aria-hidden="true">
        <div class="global-loading-card" role="status" aria-live="polite" aria-label="Loading">
            <div class="spinner-border text-feedback global-loading-spinner" aria-hidden="true"></div>
            <p class="global-loading-title mb-1">Loading...</p>
            <p class="global-loading-text mb-0">Please wait a moment.</p>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-dark custom-navbar shadow-sm">
        <div class="container">
            <div class="navbar-mobile-bar d-lg-none">
                <a class="navbar-brand fw-bold" asp-controller="DASHBOARD" asp-action="Home">
                    <img src="https://remoteteamsolutions.com/wp-content/uploads/2024/12/Remoties-Emoji.png" alt="Remoties" loading="lazy" style="height: 28px; width: auto;" id="img_remotie_navbar" />
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <div class="navbar-shell">
                    <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="DASHBOARD" asp-action="Home">
                        <img src="~/lib/images/RTS_LOGO.png" alt="Remoties" loading="lazy" style="height: 28px; width: auto;" id="img_logo_navbar" />
                    </a>

                    <ul class="navbar-nav navbar-main-menu mb-2 mb-lg-0 align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link fw-bold @(adminActive ? "active" : string.Empty)"
                               asp-controller="ADMIN"
                               asp-action="ManageFeedBack">Feedback</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold @(surveyActive ? "active" : string.Empty)"
                               asp-controller="SURVEYS"
                               asp-action="Forms">Surveys</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold @(usersActive ? "active" : string.Empty)"
                               asp-controller="USERS"
                               asp-action="Index">Users</a>
                        </li>
                    </ul>

                    @if (isAuthenticated)
                    {
                        <ul class="navbar-nav navbar-user-menu mb-0">
                            <li class="nav-item img_user_logout"><i class="fa-solid fa-2x fa-circle-user" style="color:white;"></i></li>
                            <li class="nav-item dropdown lbl_user_logout">
                                <a class="nav-link dropdown-toggle user-menu-toggle fw-bold"
                                   href="#"
                                   id="userMenu"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    @loggedUserName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                    <li>
                                        <form asp-controller="LOGIN" asp-action="Logout" method="post" class="dropdown-form">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="container py-4" id="card_main_layout">
            @RenderBody()
        </div>
    </main>

    <footer class="footer text-center py-3">
        <div class="container">
            <small>&copy; 2026 FeedBack</small>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/2.3.8/js/dataTables.min.js"></script>

    <!-- DataTables Responsive JS -->
    <script src="https://cdn.datatables.net/responsive/3.0.6/js/dataTables.responsive.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
