@model List<FeedBack_APP.Models.SurveysDetailInfo>
@{
}


@if (Model.Count() == 0)
{
    <h3 class="text-center text-danger">NO DATA FOUND</h3>
}
else
{
    var model_g = Model.FirstOrDefault();

    <div class="row">
        <div class="col-md-8 text-start">
            <h2 class="text-feedback"><b>@model_g.NameForm</b></h2>
            <h5 class="fw-bold">Remotie: @model_g.FirstName @model_g.LastName</h5>
            <h5 class="fw-bold">Client: @model_g.CustomerName</h5>
        </div>
        <div class="col text-end">
            <span>Created: <strong>@model_g.DateSurvey.ToString("MM/dd/yyyy HH:MM tt")</strong></span>
            <br />
            <h4><span class="badge rounded-pill text-bg-primary">Answered by: @(model_g.RemotieClient == 0 ? "REMOTIE" : "CLIENT")</span></h4>
            <h2 class="fw-bold">Score <span class="badge rounded-pill text-bg-primary">@model_g.ScoreSurvey</span></h2>
        </div>
        @if(model_g.Summary_AI != null || model_g.Summary_AI != ""){
            <div class="col-md-11 ms-4 p-4 text-start card-question">
                <strong>Summary</strong>
                <label>@model_g.Summary_AI</label>
            </div>
        }
    </div>
    <br>
    <div class="p-4">
        @foreach (var item in Model.OrderBy(x => x.IdFeedbackResponseD).Select((value, index) => new { value, index }))
        {
            <div class="card-question mt-3">
                <div class="row">
                    <button class="btn btn_feedback_icon_show button-index-question"><strong>@(item.index + 1)</strong></button>
                    <div class="col-md-12 text-start">
                        <label class="ms-4">@item.value.QuestionSurvey</label>
                        <br />
                        <div class="col-md-6 p-2 card-response">
                            <strong>@item.value.ResponseSurvey</strong>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}


