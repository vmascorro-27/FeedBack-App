@model List<FeedBack_APP.Models.SurveysGeneralInfo>

@if (Model.Count() == 0)
{
    <h3 class="text-center text-danger">NO DATA FOUND</h3>
}
else
{
    <table class="table align-middle table-hover table-sm small" id="datatable_feedbacks">
        <thead>
            <tr class="text-center">
                <th class="text-bg-primary">Survey</th>
                <th class="text-bg-primary">Remotie</th>
                <th class="text-bg-primary">Department</th>
                <th class="text-bg-primary">Designation</th>
                <th class="text-bg-primary">Email</th>
                <th class="text-bg-primary">Client</th>
                <th class="text-bg-primary">Submited</th>
                <th class="text-bg-primary">View</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="text-center">
                    <td>@item.NameForm</td>
                    <td class="fw-bold text-start">@item.FirstName @item.LastName</td>
                    <td>@item.DepartmentName</td>
                    <td>@item.DesignationName</td>
                    <td>@item.Email</td>
                    <td class="fw-bold">@item.CustomerName</td>
                    <td>@item.DateSurvey.ToString("MM/dd/yyyy")</td>
                    <td>
                        <button class="btn btn_feedback_icon_show" onclick="GetSurveyDetail(@item.IdFeedbackResponseG, @item.RemotieClient);"><i class="fa fa-bars"></i></button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
