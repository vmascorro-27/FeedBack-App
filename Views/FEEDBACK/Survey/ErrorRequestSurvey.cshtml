
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>FeedBack</title>
    <link rel="icon" href="~/lib/images/RTS_emoji.ico" type="image/x-icon">
</head>
<body>
    <style>
        body {
            margin: 0;
            padding: 0;
            background: linear-gradient(150deg, rgba(186, 204, 255, 0.92) 0%, rgba(80, 223, 245, 0.92) 50%, rgb(160, 238, 255) 100%);
            background-size: cover;
            font-family: "Inter", system-ui, sans-serif;
        }

        .thank-box {
            max-width: 520px;
            margin: 3rem auto;
            padding: 1.4rem 1.8rem;
            border-radius: 1rem;
            background: linear-gradient(150deg, rgba(30, 58, 138, 0.92) 0%, rgba(30, 64, 175, 0.92) 50%, rgba(37, 99, 235, 0.92) 100%);
            color: #f8fafc;
            box-shadow: 0 8px 26px rgba(30, 58, 138, 0.35);
        }

        .thank-title {
            font-size: 1.35rem;
            font-weight: 600;
            margin-bottom: 0.4rem;
            line-height: 1.3;
        }

        .thank-accent {
            width: 32px;
            height: 3px;
            border-radius: 6px;
            background: #93c5fd;
            margin-top: 0.3rem;
        }
    </style>
    <table width="100%" align="center">
        <tr>
            <td align="center" style="padding:32px 16px;">
                <img src="https://remoteteamsolutions.com/wp-content/uploads/2024/06/logo-rts.png" width="270" height="60"
                     alt="Remote Team Solutions">
            </td>
        </tr>
        <tr>
            <td>
                <div class="thank-box">
                    <div class="thank-title">
                        @ViewBag.error_code
                    </div>
                    <div class="thank-accent"></div>
                    <p style="margin-top:0.6rem; font-size:0.95rem; line-height:1.5; color:#e5e7eb;">
                        No further action is required.
                    </p>
                </div>
            </td>
        </tr>
    </table>


</body>
</html>
